---
interface Props {
  title: string;
  description: string;
  tags: string[];
  href?: string;
}

const { title, description, tags, href } = Astro.props;
---

<a
  href={href ?? '#'}
  target={href ? '_blank' : undefined}
  rel={href ? 'noopener noreferrer' : undefined}
  class="group block rounded-2xl border border-zinc-800 bg-zinc-900/50 p-6 transition-all hover:border-zinc-600 hover:bg-zinc-900"
>
  <h3 class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">
    {title}
  </h3>
  <p class="mt-2 text-sm leading-relaxed text-zinc-400">
    {description}
  </p>
  <div class="mt-4 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full bg-zinc-800 px-3 py-1 text-xs text-zinc-300">
        {tag}
      </span>
    ))}
  </div>
</a>
