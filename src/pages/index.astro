---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';
import { GraduationCap, Briefcase, MapPin, Mail, Github, Linkedin } from 'lucide-react';
---

<Layout title="Twan Grooff — Robotics & Software Engineer">
  <Nav client:load />

  <main>
    {/* Hero */}
    <section class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-blue-400">
        Robotics &amp; Software Engineer
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-6xl">
        Twan Grooff
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-400">
        M.Sc. Robotics student at TU Delft with experience in hardware–software
        integration and robotics simulation. Interested in robotic manipulation,
        machine perception, and robotics control systems.
      </p>
      <div class="mt-4 flex items-center gap-2 text-sm text-zinc-500">
        <MapPin size={16} />
        <span>Delft, Netherlands</span>
      </div>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="#projects"
          class="inline-block rounded-full bg-blue-600 px-8 py-3 text-sm font-medium text-white transition-colors hover:bg-blue-500"
        >
          View Projects
        </a>
        <a
          href="https://github.com/Dontwanno"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-700 px-6 py-3 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white"
        >
          <Github size={16} />
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/twan-grooff"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-700 px-6 py-3 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white"
        >
          <Linkedin size={16} />
          LinkedIn
        </a>
      </div>
    </section>

    {/* About */}
    <section id="about" class="mx-auto max-w-3xl px-6 py-24">
      <h2 class="text-2xl font-bold text-white">About</h2>
      <p class="mt-4 leading-relaxed text-zinc-400">
        I'm a robotics and software engineer pursuing my M.Sc. in Robotics at
        Delft University of Technology. My background combines mechanical
        engineering with computer science, giving me a unique perspective on
        building systems that bridge the physical and digital worlds — from
        designing surgical tracking arms to simulating dynamic manipulators.
      </p>
      <p class="mt-4 leading-relaxed text-zinc-400">
        Outside of engineering, I'm a lead guitarist in a band and an endurance
        runner and cyclist.
      </p>
    </section>

    {/* Education */}
    <section class="mx-auto max-w-3xl px-6 py-24">
      <h2 class="text-2xl font-bold text-white">Education</h2>
      <div class="mt-8 space-y-8">
        <div class="relative border-l border-zinc-800 pl-8">
          <div class="absolute -left-2 top-1 h-4 w-4 rounded-full border-2 border-blue-500 bg-zinc-950"></div>
          <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
            <h3 class="text-lg font-semibold text-white">M.Sc. Robotics</h3>
            <span class="text-sm text-zinc-500">2025 – Present (Expected June 2027)</span>
          </div>
          <p class="mt-1 text-sm text-blue-400">Delft University of Technology</p>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Electives: Intelligent Control Systems, Advanced Machine Perception,
            Control in Human-Robot Interaction, Model Predictive Control.
          </p>
        </div>

        <div class="relative border-l border-zinc-800 pl-8">
          <div class="absolute -left-2 top-1 h-4 w-4 rounded-full border-2 border-zinc-600 bg-zinc-950"></div>
          <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
            <h3 class="text-lg font-semibold text-white">B.Sc. Mechanical Engineering</h3>
            <span class="text-sm text-zinc-500">Sep 2018 – April 2025</span>
          </div>
          <p class="mt-1 text-sm text-blue-400">Delft University of Technology — Minor: Computer Science</p>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Thesis: <span class="text-zinc-300">Design and Validation of a 6-DOF Patient Tracking Arm</span>
            <span class="ml-2 rounded bg-zinc-800 px-2 py-0.5 text-xs text-blue-400">Grade: 8.5</span>
          </p>
        </div>
      </div>
    </section>

    {/* Experience */}
    <section id="experience" class="mx-auto max-w-3xl px-6 py-24">
      <h2 class="text-2xl font-bold text-white">Experience</h2>
      <div class="mt-8 space-y-8">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/50 p-6">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
            <h3 class="text-lg font-semibold text-white">Data Software Engineer</h3>
            <span class="text-sm text-zinc-500">April 2025 – Present</span>
          </div>
          <p class="mt-1 text-sm text-blue-400">Triple / Hypersolid</p>
          <ul class="mt-3 space-y-2 text-sm leading-relaxed text-zinc-400">
            <li class="flex gap-2">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-zinc-600"></span>
              Designing and maintaining Azure-based data pipelines using Python and SQL, leveraging Azure Data Factory and Functions within CI/CD workflows.
            </li>
          </ul>
        </div>
      </div>
    </section>

    {/* Projects */}
    <section id="projects" class="mx-auto max-w-5xl px-6 py-24">
      <h2 class="text-2xl font-bold text-white">Projects</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <ProjectCard
          title="6-DOF Patient Tracking Arm"
          description="Designed and validated a 6-DOF patient tracking arm for maxillofacial surgery using high-precision encoders. Integrated the full hardware–software stack and implemented forward/inverse kinematics with calibration procedures. Conducted accuracy validation experiments to ensure surgical-grade precision."
          tags={['Robotics', 'Kinematics', 'Python', 'SolidWorks', 'Hardware']}
        />
        <ProjectCard
          title="Dynamic Manipulator Simulation"
          description="Built a dynamic robot manipulator simulation from scratch in C++ using OpenGL for real-time 3D visualization. A personal project driven by a passion for understanding robotic systems at a fundamental level."
          tags={['C++', 'OpenGL', 'Robotics', 'Simulation', 'Dynamics']}
          href="https://github.com/Dontwanno"
        />
        <ProjectCard
          title="Azure Data Pipelines"
          description="Designing and maintaining production data pipelines on Azure, using Azure Data Factory and Functions for ETL workflows with CI/CD integration."
          tags={['Python', 'SQL', 'Azure', 'Data Factory', 'CI/CD']}
        />
      </div>
    </section>

    {/* Skills */}
    <section id="skills" class="mx-auto max-w-3xl px-6 py-24">
      <h2 class="text-2xl font-bold text-white">Skills</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-blue-400">Software</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {['Python', 'C++', 'TypeScript', 'SQL', 'Linux', 'Git'].map((s) => (
              <span class="rounded-full bg-zinc-800 px-3 py-1 text-sm text-zinc-300">{s}</span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-blue-400">Robotics</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {['ROS', 'Pinocchio', 'Drake', 'OpenGL', 'ML'].map((s) => (
              <span class="rounded-full bg-zinc-800 px-3 py-1 text-sm text-zinc-300">{s}</span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-blue-400">Cloud & Data</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {['Azure', 'Azure Data Factory', 'Azure Functions', 'CI/CD'].map((s) => (
              <span class="rounded-full bg-zinc-800 px-3 py-1 text-sm text-zinc-300">{s}</span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-blue-400">Hardware & CAD</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {['SolidWorks (CSWA)', '3D Printing', 'ESP32', 'Arduino'].map((s) => (
              <span class="rounded-full bg-zinc-800 px-3 py-1 text-sm text-zinc-300">{s}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Languages */}
    <section class="mx-auto max-w-3xl px-6 pb-24">
      <h2 class="text-2xl font-bold text-white">Languages</h2>
      <div class="mt-6 flex gap-6">
        <div class="flex items-center gap-3">
          <span class="text-sm font-medium text-zinc-300">Dutch</span>
          <span class="rounded-full bg-zinc-800 px-3 py-1 text-xs text-zinc-400">Native</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm font-medium text-zinc-300">English</span>
          <span class="rounded-full bg-zinc-800 px-3 py-1 text-xs text-zinc-400">Fluent</span>
        </div>
      </div>
    </section>

    {/* Contact */}
    <section id="contact" class="mx-auto max-w-3xl px-6 py-24">
      <h2 class="text-2xl font-bold text-white">Get in Touch</h2>
      <p class="mt-4 leading-relaxed text-zinc-400">
        Interested in working together or want to chat about robotics? Feel free to reach out.
      </p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a
          href="mailto:twan.grooff@xs4all.nl"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-700 px-8 py-3 text-sm font-medium text-white transition-colors hover:border-blue-500 hover:text-blue-400"
        >
          <Mail size={16} />
          twan.grooff@xs4all.nl
        </a>
        <a
          href="https://linkedin.com/in/twan-grooff"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-700 px-8 py-3 text-sm font-medium text-white transition-colors hover:border-blue-500 hover:text-blue-400"
        >
          <Linkedin size={16} />
          LinkedIn
        </a>
        <a
          href="https://github.com/Dontwanno"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-700 px-8 py-3 text-sm font-medium text-white transition-colors hover:border-blue-500 hover:text-blue-400"
        >
          <Github size={16} />
          GitHub
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
