---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

let projects: any[] = [];
try {
  projects = await getCollection('projects');
} catch (e) {
  // Collection might be empty or missing yet
}
const sortedProjects = projects?.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()) || [];
---

<Layout title="Projects | Robotics Portfolio">
	<div class="py-12">
		<h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-8">
			Projects & Research
		</h1>
		<p class="text-lg text-slate-600 dark:text-slate-300 mb-12 max-w-2xl">
			A collection of my work in robotics, focusing on control theory, motion planning, and autonomous systems.
		</p>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			{sortedProjects.map((project) => (
				<article class="flex flex-col p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md transition-shadow">
					<h2 class="text-xl font-bold mb-2">
						<a href={`/projects/${project.id}`} class="hover:text-blue-600 dark:hover:text-blue-400">
							{project.data.title}
						</a>
					</h2>
					<p class="text-sm text-slate-500 dark:text-slate-400 mb-4">
						{project.data.pubDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						})}
					</p>
					<p class="text-slate-700 dark:text-slate-300 mb-6 flex-grow">
						{project.data.description}
					</p>

					<div class="flex flex-wrap gap-2 mb-4">
						{project.data.tags.map((tag: string) => (
							<span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs font-medium rounded-md text-slate-600 dark:text-slate-300">
								{tag}
							</span>
						))}
					</div>

					{project.data.githubRepo && (
						<div class="mt-auto pt-4 border-t border-slate-100 dark:border-slate-800">
							<a
								href={project.data.githubRepo}
								target="_blank"
								rel="noopener noreferrer"
								class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline"
							>
								View Repository →
							</a>
						</div>
					)}
				</article>
			))}
		</div>

		{sortedProjects.length === 0 && (
			<div class="p-8 text-center border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl">
				<p class="text-slate-500 dark:text-slate-400">
					No projects have been added yet. Check back soon!
				</p>
			</div>
		)}
	</div>
</Layout>
