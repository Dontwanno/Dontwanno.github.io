---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portfolio of an MSc Robotics student at TU Delft" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-50 min-h-screen flex flex-col font-sans">
		<header class="w-full border-b border-slate-200 dark:border-slate-800">
			<nav class="max-w-5xl mx-auto px-4 py-4 flex justify-between items-center">
				<a href="/" class="text-xl font-bold tracking-tight">Robotics Portfolio</a>
				<ul class="flex space-x-6">
					<li><a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Home</a></li>
					<li><a href="/projects" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Projects</a></li>
				</ul>
			</nav>
		</header>
		<main class="flex-grow max-w-5xl mx-auto px-4 py-8 w-full">
			<slot />
		</main>
		<footer class="w-full border-t border-slate-200 dark:border-slate-800 py-6 mt-auto">
			<div class="max-w-5xl mx-auto px-4 text-center text-sm text-slate-500 dark:text-slate-400">
				&copy; {new Date().getFullYear()} Robotics Portfolio. All rights reserved.
			</div>
		</footer>
	</body>
</html>
